{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "alt": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "Dimensions": {
      "type": "object",
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      },
      "required": [
        "width",
        "height"
      ]
    },
    "year": {
      "type": "string"
    },
    "medium": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "areaOfInterest": {
      "type": "string",
      "enum": [
        "top",
        "centre",
        "bottom"
      ]
    },
    "category": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "alt",
    "id",
    "image",
    "Dimensions",
    "year",
    "medium",
    "active",
    "areaOfInterest",
    "category",
    "order"
  ]
}